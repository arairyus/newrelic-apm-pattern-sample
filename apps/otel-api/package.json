{
  "name": "newrelic-apm-pattern-sample-otel-api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter sample-core build && tsc -p tsconfig.json",
    "start": "node -r newrelic dist/apps/otel-api/src/index.js",
    "start:dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.218.0",
    "express": "^4.21.2",
    "newrelic": "^14.1.0",
    "pg": "^8.21.0",
    "sample-core": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
