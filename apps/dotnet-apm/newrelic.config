<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns="urn:newrelic-config" agentEnabled="true">
  <service />
  <application />
  <log level="info" />
  <distributedTracing enabled="true" />
  <applicationLogging enabled="true">
    <forwarding enabled="true" />
    <metrics enabled="true" />
  </applicationLogging>
</configuration>
